# ============================================================
#  AniStrim2 — Environment Variables
#  Copy this file to .env and fill in your real values
#  NEVER commit .env to Git
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# MySQL Database (MySQL Workbench)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=anistrim2

# JWT Secret — generate a long random string
JWT_SECRET=change_this_to_a_very_long_random_secret_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# Flutterwave (get keys from dashboard.flutterwave.com)
FLW_PUBLIC_KEY=FLWPUBK_TEST-XXXXXXXXXXXXXXXXXXXX-X
FLW_SECRET_KEY=FLWSECK_TEST-XXXXXXXXXXXXXXXXXXXX-X
FLW_ENCRYPTION_KEY=XXXXXXXXXXXXXXXXXXXXXXXX
FLW_WEBHOOK_SECRET=your_webhook_secret_here

# Payment Plans (in UGX)
PREMIUM_MONTHLY_AMOUNT=35000
PREMIUM_YEARLY_AMOUNT=350000

# Frontend URL (for redirects after payment)
FRONTEND_URL=http://localhost:5000

# Admin
ADMIN_EMAIL=admin@anistrim.com

# Cloudinary media storage and video delivery
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Automated catalogue providers. Kitsu works without a key; deploy Consumet
# yourself and set its private base URL. MalSync mapping is optional until a
# compatible MAL-ID bridge is configured.
REDIS_URL=redis://default:pY1jVyBmQFuc2c66et5eMyP6D2yJ8rNj@sincere-size-upbeat-53194.db.redis.io:19093
KITSU_BASE_URL=https://kitsu.io/api/edge
MALSYNC_BASE_URL=https://api.malsync.moe
CONSUMET_BASE_URL=https://your-private-consumet-service.example
PROVIDER_TIMEOUT_MS=8000
